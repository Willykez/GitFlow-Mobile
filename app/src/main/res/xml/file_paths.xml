<?xml version="1.0" encoding="utf-8"?>
<!-- Tells FileProvider which of this app's folders it's allowed to hand out
     content:// URIs for — nothing else in the app's storage is reachable
     through this provider. -->
<paths>
    <!-- Downloaded debug/release APKs from the Actions screen — these live in
         shared/public storage (Environment.getExternalStorageDirectory()),
         under .GitFlow/release/, not the app's private cache, so they stay
         reachable (and re-installable) through a normal file manager even
         outside this app. -->
    <external-path name="release_downloads" path=".GitFlow/release/" />
</paths>
